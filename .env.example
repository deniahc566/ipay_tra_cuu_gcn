# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret for signing OTP JWTs (min 32 chars — generate with the command below)
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=replace_with_32_char_random_secret

# Secret for iron-session cookie encryption (min 32 chars, DIFFERENT from JWT_SECRET)
SESSION_PASSWORD=replace_with_different_32_char_random_secret

# Email domain allowed to log in (e.g. vbi.com.vn)
# Only users whose email ends with @<this domain> can request an OTP
ALLOWED_EMAIL_DOMAIN=vbi.com.vn

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must match a verified sender domain in your Resend account
EMAIL_FROM=noreply@vbi.com.vn

# ── VBI External API ──────────────────────────────────────────────────────────
VBI_API_KEY=your_vbi_api_key_here
VBI_CANCEL_API_KEY=your_vbi_cancel_api_key_here

# ── Cancel permissions ─────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to use the cancel feature
CANCEL_ALLOWED_EMAILS=user1@vbi.com.vn,user2@vbi.com.vn
# Same list, exposed to the browser for UI (greying out the button)
NEXT_PUBLIC_CANCEL_ALLOWED_EMAILS=user1@vbi.com.vn,user2@vbi.com.vn

# ── MotherDuck ────────────────────────────────────────────────────────────────
MOTHERDUCK_TOKEN=your_motherduck_token_here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
